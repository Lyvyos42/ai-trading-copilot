# ─────────────────────────────────────────────────────────────────────────────
# AI Trading Copilot — Production Environment Variables (Render.com backend)
# ─────────────────────────────────────────────────────────────────────────────
# Copy these into the Render dashboard under Environment → Add Environment Variable

# PostgreSQL from Neon.tech (free tier — no credit card needed)
# Sign up at https://neon.tech → Create project → copy the "psql" connection string
# Replace "postgresql://" with "postgresql+asyncpg://"
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Anthropic (your key)
ANTHROPIC_API_KEY=sk-ant-api03-...

# JWT — generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_64_char_random_hex

# CORS — set to your Vercel frontend URL (no trailing slash)
ALLOWED_ORIGINS=https://neural-edge-website.vercel.app

ENVIRONMENT=production
LOG_LEVEL=INFO
